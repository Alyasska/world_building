generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EntityStatus {
  draft
  active
  archived
}

enum CanonState {
  canonical
  alternate
  uncertain
  noncanonical
}

enum AssetKind {
  image
  document
  audio
  video
  archive
  other
}

enum MapGeometryType {
  point
  rect
  polygon
}

enum PlaceScale {
  world
  continent
  region
  country
  province
  state
  city
  town
  village
  district
  landmark
  building
  room
  site
  other
}

model Character {
  id            String              @id @default(uuid()) @db.Uuid
  name          String
  slug          String              @unique
  summary       String?
  content       Json?
  status        EntityStatus        @default(draft)
  canonState    CanonState          @default(canonical)
  metadata      Json?
  aliases       Json?
  pronouns      String?
  epithet       String?
  birthDateText String?
  deathDateText String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  deletedAt     DateTime?

  fromRelations CharacterRelation[] @relation("CharacterRelationFrom")
  toRelations   CharacterRelation[] @relation("CharacterRelationTo")

  @@index([slug])
}

model Place {
  id            String             @id @default(uuid()) @db.Uuid
  name          String
  slug          String             @unique
  summary       String?
  content       Json?
  status        EntityStatus       @default(draft)
  canonState    CanonState         @default(canonical)
  metadata      Json?
  placeScale    PlaceScale         @default(other)
  placeKind     String?
  parentPlaceId String?            @db.Uuid
  locationText  String?
  aliases       Json?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  deletedAt     DateTime?

  fromConnections PlaceConnection[] @relation("PlaceConnectionFrom")
  toConnections   PlaceConnection[] @relation("PlaceConnectionTo")
  stories         Story[]
  events          Event[]
  mapRegions      MapRegion[]
  parentPlace     Place?            @relation("PlaceHierarchy", fields: [parentPlaceId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  childPlaces     Place[]           @relation("PlaceHierarchy")

  @@index([slug])
  @@index([placeScale])
  @@index([parentPlaceId])
}

model Story {
  id            String          @id @default(uuid()) @db.Uuid
  title         String
  slug          String          @unique
  summary       String?
  content       Json?
  status        EntityStatus    @default(draft)
  canonState    CanonState      @default(canonical)
  metadata      Json?
  storyKind     String?
  primaryPlaceId String?        @db.Uuid
  startDateText String?
  endDateText   String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?

  primaryPlace  Place?          @relation(fields: [primaryPlaceId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  events        Event[]
  storyEntities StoryEntity[]

  @@index([slug])
  @@index([primaryPlaceId])
}

model Event {
  id            String          @id @default(uuid()) @db.Uuid
  title         String
  slug          String          @unique
  summary       String?
  content       Json?
  status        EntityStatus    @default(draft)
  canonState    CanonState      @default(canonical)
  metadata      Json?
  storyId       String?         @db.Uuid
  placeId       String?         @db.Uuid
  /// Free-text in-world date label (e.g. "Year 342 of the Third Age"). This is the
  /// canonical display value for fictional-world events. Always prefer this for UI.
  eventDateText String?
  /// Structured ISO timestamp for machine sorting and real-calendar overlay.
  /// Optional and secondary to eventDateText. Null for most fictional-world events.
  startAt       DateTime?
  /// Structured ISO timestamp — see startAt notes above.
  endAt         DateTime?
  /// Valid values defined in lib/event-date-precision.ts. Stored as String because
  /// Prisma enum migrations are heavy; Zod schema enforces the allowed set at runtime.
  datePrecision String?         @default("unknown")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?

  story         Story?          @relation(fields: [storyId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  place         Place?          @relation(fields: [placeId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  participants  EventParticipant[]

  @@index([slug])
  @@index([storyId])
  @@index([placeId])
}

model Faction {
  id            String          @id @default(uuid()) @db.Uuid
  name          String
  slug          String          @unique
  summary       String?
  content       Json?
  status        EntityStatus    @default(draft)
  canonState    CanonState      @default(canonical)
  metadata      Json?
  factionKind   String?
  emblemAssetId String?         @db.Uuid
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?

  @@index([slug])
}

model LoreEntry {
  id          String          @id @default(uuid()) @db.Uuid
  title       String
  slug        String          @unique
  summary     String?
  content     Json?
  status      EntityStatus    @default(draft)
  canonState  CanonState      @default(canonical)
  metadata    Json?
  entryKind   String?
  topic       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?

  @@index([slug])
}

model RuleSystem {
  id           String          @id @default(uuid()) @db.Uuid
  title        String
  slug         String          @unique
  summary      String?
  content      Json?
  status       EntityStatus    @default(draft)
  canonState   CanonState      @default(canonical)
  metadata     Json?
  systemKind   String?
  versionLabel String?
  appliesTo    String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  deletedAt    DateTime?

  @@index([slug])
}

model Asset {
  id         String          @id @default(uuid()) @db.Uuid
  name       String
  slug       String          @unique
  summary    String?
  content    Json?
  status     EntityStatus    @default(draft)
  canonState CanonState      @default(canonical)
  metadata   Json?
  assetKind  AssetKind       @default(other)
  storageKey String
  fileName   String
  mimeType   String
  byteSize   BigInt?
  checksum   String?
  altText    String?
  sourceUri  String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  deletedAt  DateTime?

  @@index([slug])
  @@index([storageKey])
}

model Tag {
  id         String          @id @default(uuid()) @db.Uuid
  name       String
  slug       String          @unique
  summary    String?
  content    Json?
  status     EntityStatus    @default(draft)
  canonState CanonState      @default(canonical)
  metadata   Json?
  color      String?
  namespace  String          @default("world")
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  deletedAt  DateTime?

  @@index([slug])
}

model Map {
  id             String      @id @default(uuid()) @db.Uuid
  name           String
  slug           String      @unique
  summary        String?
  content        Json?
  status         EntityStatus @default(draft)
  canonState     CanonState   @default(canonical)
  metadata       Json?
  mapKind        String?
  defaultLayerKey String      @default("base")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  regions        MapRegion[]

  @@index([slug])
}

model MapRegion {
  id           String            @id @default(uuid()) @db.Uuid
  name         String
  slug         String            @unique
  summary      String?
  content      Json?
  status       EntityStatus      @default(draft)
  canonState   CanonState        @default(canonical)
  metadata     Json?
  mapId        String            @db.Uuid
  placeId      String?           @db.Uuid
  layerKey     String            @default("base")
  geometryType MapGeometryType
  geometry     Json
  labelPoint   Json?
  displayOrder Int               @default(0)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  deletedAt    DateTime?

  map          Map               @relation(fields: [mapId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  place        Place?            @relation(fields: [placeId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  links        MapRegionLink[]

  @@index([slug])
  @@index([mapId])
  @@index([placeId])
  @@index([mapId, layerKey])
}

model CharacterRelation {
  id              String       @id @default(uuid()) @db.Uuid
  fromCharacterId  String       @db.Uuid
  toCharacterId    String       @db.Uuid
  relationType     String
  status           EntityStatus @default(draft)
  canonState       CanonState   @default(canonical)
  metadata         Json?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  deletedAt        DateTime?

  fromCharacter    Character    @relation("CharacterRelationFrom", fields: [fromCharacterId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  toCharacter      Character    @relation("CharacterRelationTo", fields: [toCharacterId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([fromCharacterId])
  @@index([toCharacterId])
  @@index([relationType])
}

model EntityLink {
  id              String       @id @default(uuid()) @db.Uuid
  fromEntityType  String
  fromEntityId    String       @db.Uuid
  toEntityType    String
  toEntityId      String       @db.Uuid
  relationType    String
  isBidirectional Boolean      @default(false)
  status          EntityStatus @default(draft)
  canonState      CanonState   @default(canonical)
  metadata        Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?

  @@index([fromEntityType, fromEntityId])
  @@index([toEntityType, toEntityId])
  @@index([relationType])
}

model EventParticipant {
  id               String       @id @default(uuid()) @db.Uuid
  eventId          String       @db.Uuid
  participantType  String
  participantId    String       @db.Uuid
  participantRole  String
  sequence         Int?
  note             String?
  status           EntityStatus @default(draft)
  canonState       CanonState   @default(canonical)
  metadata         Json?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  deletedAt        DateTime?

  event            Event        @relation(fields: [eventId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([eventId])
  @@index([participantType, participantId])
  @@index([participantRole])
}

/// StoryEntity connects a Story to non-event-based entities: thematic Place anchors,
/// Faction associations, LoreEntry references, etc.
/// DO NOT use this to attach Characters to Stories. Characters connect to Stories
/// through EventParticipant → Event.storyId, which preserves the narrative context
/// (when and where the character was involved). StoryEntity is for thematic membership
/// that is not tied to a specific event. Service and API not yet built — reserved scaffold.
model StoryEntity {
  id           String       @id @default(uuid()) @db.Uuid
  storyId      String       @db.Uuid
  entityType   String
  entityId     String       @db.Uuid
  entityRole   String
  sequence     Int?
  note         String?
  status       EntityStatus @default(draft)
  canonState   CanonState   @default(canonical)
  metadata     Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  story        Story        @relation(fields: [storyId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([storyId])
  @@index([entityType, entityId])
  @@index([entityRole])
}

model PlaceConnection {
  id              String       @id @default(uuid()) @db.Uuid
  fromPlaceId     String       @db.Uuid
  toPlaceId       String       @db.Uuid
  connectionType  String
  isBidirectional Boolean      @default(true)
  distanceKm      Float?
  travelTimeText  String?
  status          EntityStatus @default(draft)
  canonState      CanonState   @default(canonical)
  metadata        Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?

  fromPlace       Place @relation("PlaceConnectionFrom", fields: [fromPlaceId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  toPlace         Place @relation("PlaceConnectionTo", fields: [toPlaceId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([fromPlaceId])
  @@index([toPlaceId])
  @@index([connectionType])
}

model EntityTag {
  id          String       @id @default(uuid()) @db.Uuid
  entityType  String
  entityId    String       @db.Uuid
  tagId       String       @db.Uuid
  context     String?
  status      EntityStatus @default(draft)
  canonState  CanonState   @default(canonical)
  metadata    Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  tag         Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([entityType, entityId])
  @@index([tagId])
}

model AssetLink {
  id          String       @id @default(uuid()) @db.Uuid
  assetId     String       @db.Uuid
  entityType  String
  entityId    String       @db.Uuid
  usageType   String
  status      EntityStatus @default(draft)
  canonState  CanonState   @default(canonical)
  metadata    Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  asset       Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([assetId])
  @@index([entityType, entityId])
  @@index([usageType])
}

model MapRegionLink {
  id          String       @id @default(uuid()) @db.Uuid
  regionId    String       @db.Uuid
  entityType  String
  entityId    String       @db.Uuid
  linkType    String
  isPrimary   Boolean      @default(false)
  status      EntityStatus @default(draft)
  canonState  CanonState   @default(canonical)
  metadata    Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  region      MapRegion    @relation(fields: [regionId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([regionId])
  @@index([entityType, entityId])
  @@index([linkType])
}
